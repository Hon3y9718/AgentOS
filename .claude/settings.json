{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(secrets/**)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(cat .env*)",
      "Bash(source .env*)",
      "Bash(env)",
      "Bash(printenv*)",
      "Bash(docker exec *)"
    ]
  },
  "enabledPlugins": {
    "discord@claude-plugins-official": true
  }
}
