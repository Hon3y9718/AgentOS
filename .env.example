# Copy to .env and fill in. app/config.py is the only place these are read
# (CI greps for stray os.getenv calls) — see docs/ARCHITECTURE.md#configuration.

# Postgres connection string, async driver. Matches docker-compose's postgres
# service when run via `make dev` from the host (pytest, alembic); the api
# container itself gets DATABASE_URL overridden to use the "postgres" hostname.
DATABASE_URL="postgresql+asyncpg://agentos:agentos@localhost:5432/agentos"

# Signs JWT access tokens (app/core/auth/backend.py) and, for now, also
# fastapi-users' reset-password/verification tokens (app/core/auth/manager.py
# — those flows aren't exposed by any endpoint yet). Required, no default —
# app/config.py crashes at startup if this is missing, same as DATABASE_URL.
# Generate a real one with `openssl rand -hex 32`; the value below is only
# for local dev.
SECRET_KEY="dev-only-secret-do-not-use-in-production"

# One of DEBUG, INFO, WARNING, ERROR, CRITICAL. Controls structlog's minimum level.
LOG_LEVEL="INFO"

# OpenAI API key. Missing key marks openai models `available: false`, doesn't crash.
OPENAI_API_KEY=""

# Anthropic API key. Missing key marks anthropic models `available: false`, doesn't crash.
ANTHROPIC_API_KEY=""

# Together AI API key. Missing key marks together models `available: false`, doesn't crash.
TOGETHER_API_KEY=""

# Groq API key. Missing key marks groq models `available: false`, doesn't crash.
GROQ_API_KEY=""

# Google Gemini API key. Missing key marks gemini models `available: false`, doesn't crash.
GEMINI_API_KEY=""
